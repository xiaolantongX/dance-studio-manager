{
  "name": "dance-studio-manager",
  "version": "1.0.0",
  "description": "舞蹈室业绩管理系统 - 桌面端",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "electron:build": "vite build && electron-builder",
    "electron:preview": "electron ."
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "electron-store": "^8.1.0",
    "node-schedule": "^2.1.1",
    "vue": "^3.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "vite": "^5.0.0",
    "vite-plugin-singlefile": "^2.3.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.dancestudio.manager",
    "productName": "舞蹈室业绩管理",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist/index.html",
      "dist/assets/**/*",
      "src/main/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    }
  }
}
